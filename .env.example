# Gmail SMTP for email notifications
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Fill in the values below

GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL_TO=youremail@gmail.com

# WhatsApp number for the "let's talk" button on the closing stage.
# Format: country code + number, no '+', no spaces.
# Example for Indonesia (+62): 6281234567890
# If left empty, the button will not appear (the rest still works fine).
# NOTE: This is exposed in the client bundle (NEXT_PUBLIC prefix).
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890
